{
  "info": {
    "_postman_id": "b25cf1d2-36da-4d89-b671-analysiscollector",
    "name": "Analysis Collector API",
    "description": "Postman collection for analysis-collector. Authenticated requests use the collection bearer token variable `access_token`. Run `Staging Auth / Issue master token` first on staging to populate it automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://analysis-staging.choicedx.kr/api",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "batch_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "customer_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "consultant_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Staging Auth",
      "item": [
        {
          "name": "Issue master token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const token = body?.data?.access_token || body?.access_token;",
                  "pm.test('access_token exists', function () {",
                  "  pm.expect(token).to.be.a('string').and.not.empty;",
                  "});",
                  "if (token) {",
                  "  pm.collectionVariables.set('access_token', token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/staging/auth/master-token",
              "host": ["{{base_url}}"],
              "path": ["staging", "auth", "master-token"]
            },
            "description": "Staging-only helper. The response interceptor wraps the token under `data.access_token`; the test script stores it as `access_token`."
          },
          "response": []
        }
      ]
    },
    {
